<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/style.css" />
    <title>Get CRUD</title>
  </head>
  <body>
    <div class="topnav">
      <a class="active" href="#home">Home</a>
      <a href="#news">News</a>
      <a href="#contact">Contact</a>
      <a href="#about">About</a>
    </div>

    <div class="container">
      <h2>List users:</h2>
      <table class="user-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Email</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Address</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <!-- Vòng lặp ============ -->
          <% for(let i = 0; i < datatable.length; i++) { %>
            <tr>
              <td><%= datatable[i].id %></td>
              <td><%= datatable[i].email %></td>
              <td><%= datatable[i].firstName %></td>
              <td><%= datatable[i].lastName %></td>
              <td><%= datatable[i].address %></td>
              <td>
                <!-- User rows will go here -->
                <a href="/detail-crud/<%= datatable[i].id %>">
                    <button class="btn" type="button">Detail</button>
                </a> 
                <a href="/edit-crud?id=<%= datatable[i].id %>">
                    <button class="btn" type="button">Edit</button>
                </a> 
                <a href="/delete-crud/<%= datatable[i].id %>">
                    <button class="btn" type="button">Delete</button>
                </a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </body>
</html>
